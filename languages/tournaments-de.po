#: zzbrick_make/standings.inc.php
msgid ""
"Standings update for round %d impossible: So far only %d round has been "
"played."
msgid_plural ""
"Standings update for round %d impossible: So far only %d rounds have been "
"played."
msgstr[0] ""
"Aktualisierung der Rangliste für Runde %d unmöglich: Bislang wurde nur %d "
"Runde gespielt."
msgstr[1] ""
"Aktualisierung der Rangliste für Runde %d unmöglich: Bislang wurden nur %d "
"Runden gespielt."

#: zzbrick_make/standings.inc.php
msgid ""
"Attempted to update a round that is higher than the maximum number of rounds."
msgstr ""
"Es wurde versucht, eine Runde zu aktualisieren, die höher als die maximale "
"Anzahl von Runden ist."

#: zzbrick_make/standings.inc.php
msgid ""
"Standings update for round %d impossible: No games were played in this round."
msgstr ""
"Tabellenaktualisierung für Runde %d unmöglich: In dieser Runde wurden keine "
"Partien gespielt."

#: zzbrick_make/standings.inc.php
msgid "Standings for tournament %s, round %d have been successfully updated."
msgstr ""
"Der Tabellenstand für Turnier %s, Runde %d wurde erfolgreich aktualisiert."

#: zzbrick_make/standings.inc.php
msgid "Standings for tournament %s, round %d: no updates necessary."
msgstr ""
"Tabellenstand für Turnier %s, Runde %d: keine Aktualisierung erforderlich."

#: zzbrick_make/standings.inc.php
msgid "Standings update for tournament %s, round %d already in progress."
msgstr ""
"Tabellenaktualisierung für Turnier %s, Runde %d läuft bereits."

